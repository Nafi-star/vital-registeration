# Database (PostgreSQL). Replace with your credentials.
# Example: postgresql://USER:PASSWORD@localhost:5432/vital_db
# Docker: postgresql://postgres:postgres@localhost:5432/vital_db
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vital_db"

# Optional: port for the API (default 3000)
# PORT=3000

# Optional: CORS origin for the frontend (default http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

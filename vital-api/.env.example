# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vital_registration?schema=public"

# Server
PORT=3000
NODE_ENV=development

# CORS: single origin or comma-separated list (production)
CORS_ORIGIN=http://localhost:5173

# JWT — use a long random string in production (openssl rand -base64 48)
JWT_SECRET=change-me-in-production
# Expiry as seconds (number) or string understood by jsonwebtoken, e.g. 28800 or 8h
JWT_EXPIRES_SEC=8h

# Admin login (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional second admin
# BACKUP_ADMIN_USERNAME=
# BACKUP_ADMIN_PASSWORD=
